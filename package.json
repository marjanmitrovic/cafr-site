{
  "name": "cafr-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --env-file=.env --watch server/server.js",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "build": "vite build",
    "test:cards": "node --check public/member-card-system.js && node --check public/simple-member-card.js && node --test tests/member-card-template.test.mjs",
    "db:generate": "prisma generate --config ./prisma.config.ts",
    "db:push": "prisma db push --config ./prisma.config.ts",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "start:production": "node server/server.js",
    "preview": "vite preview --host 0.0.0.0",
    "start:api": "node --env-file=.env server/server.js",
    "db:studio": "node --env-file=.env ./node_modules/prisma/build/index.js studio --config ./prisma.config.ts",
    "render:build": "npm run db:generate && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "prisma": "^7.8.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "resend": "^6.0.0"
  }
}
