DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/cafr?sslmode=require"
API_PORT=3001
WEB_ORIGIN=http://localhost:5173
TOKEN_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@cafr.cz
ADMIN_PASSWORD=CAFR-change-me-2026

# Email notifications (Resend HTTP API; no npm package required)
# In development, if RESEND_API_KEY is empty, emails are logged/skipped and reset links are returned in the API response.
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="ČAFR <onboarding@resend.dev>"
ADMIN_NOTIFY_EMAIL="marjan.posao@gmail.com"
EMAIL_DISABLED="false"
NODE_ENV="development"

# Replace re_xxxxxxxxx with your real Resend API key before production email testing.

# Production example
# WEB_ORIGIN=https://your-render-service.onrender.com
# NODE_ENV=production
# EMAIL_FROM="ČAFR <no-reply@cafr.cz>"  # only after cafr.cz is verified in Resend

# File uploads
# local = save in public/uploads (good for local development)
# cloudinary = upload files to Cloudinary using an unsigned upload preset
FILE_STORAGE="local"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET=""
CLOUDINARY_FOLDER="cafr"
